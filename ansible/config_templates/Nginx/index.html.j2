<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>{{ inventory_hostname }}</title>
  <style>
    body { font-family: sans-serif; padding: 2em; background: #f5f5f5; }
    h1 { color: #333; }
    .host { color: #c00; font-weight: bold; }
    .info { background: #fff; padding: 1em; border-radius: 6px; max-width: 480px; }
    .info p { margin: 0.4em 0; }
  </style>
</head>
<body>
  <h1>Hello from <span class="host">{{ inventory_hostname }}</span></h1>
  <div class="info">
    <p>호스트: <b>{{ inventory_hostname }}</b></p>
    <p>IP:    <b>{{ ansible_host }}</b></p>
    <p>VLAN:  <b>20 (SRV) - 172.16.20.0/27</b></p>
  </div>
</body>
</html>
