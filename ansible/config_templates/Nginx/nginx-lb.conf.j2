# ===== {{ inventory_hostname }} - Nginx LB + Backend =====
# Ansible 자동 생성

upstream backend_pool {
    least_conn;
{% for be in upstream_backends %}
    server {{ be.host }}:{{ be.port }} max_fails=3 fail_timeout=10s;  # {{ be.name }}
{% endfor %}
}

server {
    listen {{ lb_listen_port }} default_server;
    server_name _;

    location / {
        proxy_pass http://backend_pool;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_connect_timeout 5s;
        proxy_read_timeout    30s;
    }

    location /lb-health {
        return 200 "LB OK on {{ inventory_hostname }}\n";
        add_header Content-Type text/plain;
    }
}

server {
    listen {{ backend_listen_port }};
    server_name _;

    root  /var/www/html;
    index index.html;

    location / { try_files $uri $uri/ =404; }
}

