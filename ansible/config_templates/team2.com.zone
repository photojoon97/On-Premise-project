$TTL 3H
@       IN SOA  ns.team2.com. root.team2.com. (
                                        2026052601 ; 시리얼 번호
                                        1D         ; 리프레시
                                        1H         ; 리트라이
                                        1W         ; 익스파이어
                                        3H )       ; 네거티브 캐시 TTL

;
        IN NS   ns.team2.com.

;
@       IN A    172.16.20.29     ; team2.com 접속 시 nginx1로 연결
www     IN A    172.16.20.30     ; www.team2.com 접속 시 nginx2로 연결

; 
ns      IN A    172.16.20.10     ; 
dhcp    IN A    172.16.20.20     ; 
nginx1  IN A    172.16.20.29     ;
nginx2  IN A    172.16.20.30     ;
